# Hugging Face Configuration (Free API - Required if not using OpenAI/Gemini)
HUGGINGFACE_API_KEY=your_huggingface_api_token_here
# Optional: Specify models to use on Hugging Face (default: meta-llama/Llama-3.3-70B-Instruct)
HUGGINGFACE_MODEL=meta-llama/Llama-3.3-70B-Instruct
# Optional: Specify image generation model on Hugging Face (default: black-forest-labs/FLUX.1-schnell)
HUGGINGFACE_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# LangChain Tracing (Optional)
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=blog-writing-agent

# Optional Search API Key (If omitted, DuckDuckGo Search will be used automatically for free)
TAVILY_API_KEY=

# Optional Paid Provider Keys (For fallbacks)
OPENAI_API_KEY=
GOOGLE_API_KEY=
